Windows Registry Editor Version 5.00

; Cleanup existing System Tools keys before re-applying
[-HKEY_CURRENT_USER\Software\Classes\*\shell\SystemTools]
[-HKEY_CURRENT_USER\Software\Classes\Directory\shell\SystemTools]
[-HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\SystemTools]
[-HKEY_CURRENT_USER\Software\Classes\DesktopBackground\Shell\SystemTools]
[-HKEY_CLASSES_ROOT\*\shell\SystemTools]
[-HKEY_CLASSES_ROOT\Directory\shell\SystemTools]
[-HKEY_CLASSES_ROOT\Directory\Background\shell\SystemTools]
[-HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemTools]

; Parent menu (files)
[HKEY_CURRENT_USER\Software\Classes\*\shell\SystemTools]
"MUIVerb"="System Tools"
"SubCommands"=""
"Icon"="imageres.dll,-109"

; Parent menu
[HKEY_CURRENT_USER\Software\Classes\Directory\shell\SystemTools]
"MUIVerb"="System Tools"
"SubCommands"=""
"Icon"="imageres.dll,-109"

; Submenu: PATH manager
[HKEY_CURRENT_USER\Software\Classes\Directory\shell\SystemTools\shell\PathManager]
"MUIVerb"="Manage Folder PATH..."
"Icon"="D:\\Users\\joty79\\scripts\\SystemTools\\.assets\\icons\\folder_to_path.ico"


[HKEY_CURRENT_USER\Software\Classes\Directory\shell\SystemTools\shell\PathManager\command]
@="wscript.exe \"D:\\Users\\joty79\\scripts\\SystemTools\\Launch-SystemToolsMenu.vbs\" \"%1\""

; Submenu: Restart Explorer
[HKEY_CURRENT_USER\Software\Classes\Directory\shell\SystemTools\shell\RestartExplorer]
"MUIVerb"="Restart Explorer"
"Icon"="D:\\Users\\joty79\\scripts\\SystemTools\\.assets\\icons\\restart_explorer.ico"

[HKEY_CURRENT_USER\Software\Classes\Directory\shell\SystemTools\shell\RestartExplorer\command]
@="wscript.exe \"D:\\Users\\joty79\\scripts\\SystemTools\\Launch-RestartExplorer.vbs\" \"%1\""

